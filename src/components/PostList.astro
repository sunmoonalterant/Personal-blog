---
const { posts } = Astro.props;
const base = import.meta.env.BASE_URL;
import { withBase } from '../lib/urls.js';
const formatDate = (date) => new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<div class="post-list">
  {posts.map((post) => (
    <article class="post-row">
      <div class="record-label">LOG / NOTE</div>
      <div><time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time><span> / {post.data.tags[0] ?? '随笔'}</span></div>
      <h3><a href={withBase(base, `blog/${post.id}/`)}>{post.data.title}</a></h3>
      <p>{post.data.description}</p>
    </article>
  ))}
</div>
