---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="文章｜林野" description="关于创作、设计与生活的写作笔记。"><section class="shell page-intro"><p class="eyebrow">Writing</p><h1>写下正在想的事。</h1><p>有关创作、设计与慢慢变得更清楚的生活。</p></section><section class="shell section"><PostList posts={posts} /></section></BaseLayout>
